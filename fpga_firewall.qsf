set_instance_assignment -name IO_STANDARD "3.3-V LVTTL" -to cfg_wdata[30]
set_instance_assignment -name IO_STANDARD "3.3-V LVTTL" -to cfg_wdata[31]

# =============================================================================
# Timing Constraints
# =============================================================================

# Create clock for 125 MHz system clock
create_clock -period 8.000 -name "clk_125mhz" [get_ports {clk_125mhz}]

# Create clock for RGMII receive (derived from PHY)
create_clock -period 8.000 -name "rgmii_rx_clk" [get_ports {rgmii_rx_clk}]

# Set input delay for RGMII RX signals (relative to rx_clk)
set_input_delay -clock rgmii_rx_clk -max 1.0 [get_ports {rgmii_rxd[*] rgmii_rx_ctl}]
set_input_delay -clock rgmii_rx_clk -min 0.5 [get_ports {rgmii_rxd[*] rgmii_rx_ctl}]

# Set output delay for RGMII TX signals
set_output_delay -clock rgmii_tx_clk -max 2.0 [get_ports {rgmii_txd[*] rgmii_tx_ctl}]
set_output_delay -clock rgmii_tx_clk -min 0.5 [get_ports {rgmii_txd[*] rgmii_tx_ctl}]

# False path between asynchronous clock domains
set_false_path -from [get_keepers {*rx_clk*}] -to [get_keepers {*tx_clk*}]
set_false_path -from [get_keepers {*tx_clk*}] -to [get_keepers {*rx_clk*}]

# =============================================================================
# Project Parameters
# =============================================================================

# Firewall parameters (can be overridden)
set_global_assignment -name VERILOG_PARAMETER MAX_FRAME_BYTES 2048
set_global_assignment -name VERILOG_PARAMETER TARGET "ALTERA"

# =============================================================================
# Additional Settings
# =============================================================================

# Enable SignalTap debugging (optional - uncomment to enable)
# set_global_assignment -name ENABLE_SIGNALTAP_LOGIC_ANALYZER ON

# Power optimization
set_global_assignment -name POWER_OPTIMIZATION "STANDARD"

# Enable register retiming for better timing
set_global_assignment -name OPTIMIZE_REGISTER_DUPLICATION ON
set_global_assignment -name REGISTER_RETIMING ON

# End of Quartus Settings File
