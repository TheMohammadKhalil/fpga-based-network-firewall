set_instance_assignment -name IO_STANDARD "3.3-V LVTTL" -to cfg_wdata[18]
set_instance_assignment -name IO_STANDARD "3.3-V LVTTL" -to cfg_wdata[19]
set_instance_assignment -name IO_STANDARD "3.3-V LVTTL" -to cfg_wdata[20]
